      "id": "d9c8a1c3-1a5d-48b7-bc03-f2d0bfb77f2c",
      "name": "OpenAI Chat Model — Intake",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        1200,
        420
      ],
      "credentials": {
        "openAiApi": {
          "name": "ROAR OpenAI"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const coerceToString = (v) => {\n  if (v == null) return '';\n  if (typeof v === 'string') return v;\n  if (typeof v === 'object') {\n    if (typeof v.text === 'string') return v.text;\n    if (typeof v.output === 'string') return v.output;\n    if (typeof v.response === 'string') return v.response;\n    if (v.response && typeof v.response.text === 'string') return v.response.text;\n  }\n  return String(v);\n};\n\nconst fallbackQuestion = 'Could you share a bit more detail about what happened with your order?';\n\nlet raw = $json;\nlet data;\n\nif (raw && typeof raw === 'object' && (raw.action || raw.question || raw.intent)) {\n  data = raw;\n} else {\n  const text = coerceToString(raw);\n  try {\n    data = JSON.parse(text);\n  } catch (e) {\n    data = { action: 'ask_question', question: fallbackQuestion };\n  }\n}\n\nconst rawIntent = (data.intent || '').toString().trim();\nconst intent = rawIntent === 'insufficient_info' ? 'insufficient_context' : rawIntent;\n\nlet next_action;\nlet question = data.question || null;\n\nif (data.action === 'ask_question') {\n  next_action = 'ask_question';\n} else if (data.action === 'classify_intent' && intent === 'valid_dispute') {\n  next_action = 'classify_intent';\n} else if (data.action === 'classify_intent' && intent === 'insufficient_context') {\n  // Keep intake interactive: ask follow-up instead of closing immediately.\n  next_action = 'ask_question';\n  question = question || fallbackQuestion;\n} else {\n  next_action = 'ask_question';\n  question = question || fallbackQuestion;\n}\n\nreturn [{\n  next_action,\n  question,\n  intent,\n  intent_summary: data.intent_summary || null,\n}];\n"
      },
