    {
      "parameters": {
        "jsCode": "const caseData = $item(0, 'Fetch Case').$json;\nconst transcript = ($item(0, 'Fetch Transcript').$json.messages || []).slice(-40);\n\nconst priorQuestions = transcript.filter(\n  (m) => m.sender_type === 'agent' && m.metadata?.role === 'intake_question'\n).length;\n\nconst userPayload = {\n  case: caseData,\n  transcript,\n  max_followup_questions: 3,\n};\n\nconst messages = [\n  {\n    role: 'user',\n    content: JSON.stringify(userPayload),\n  },\n];\n\nreturn [{ messages, priorQuestions }];\n"
      },
      "id": "e0e0e56c-1b83-4ec9-8eb2-73bde26f8b65",
      "name": "Build Intake Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        240
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.messages?.[0]?.content || '' }}",
        "messages": {
          "messageValues": [
            {
              "type": "SystemMessagePromptTemplate",
              "message": "You are ROAR's intake agent for a retail customer dispute system.\n\nYour job is to gather sufficient context from the customer about their dispute,\nthen classify the intent once you have enough information.\n\nRULES:\n\n- Ask a maximum of 3 follow-up questions total across the entire conversation.\n\n- Only ask questions from the approved set for the given dispute_type.\n\n- Use case.dispute_subtype and the transcript to decide whether item-level clarification is required.\n\n- If the customer indicates that only some items were received, some items were damaged, some items were wrong, or only a subset of the order is affected, ask an item-level follow-up before generic verification like payment method or timing.\n\n- The item-level follow-up counts toward the 3-question limit.\n\n- Do not ask an item-level follow-up if the whole order is clearly affected and there is no item ambiguity.\n\n- Once you have sufficient context (or after 3 questions), classify the intent.\n\n- Classify as valid_dispute if the issue is a legitimate refund or delivery problem.\n\n- Classify as insufficient_context only if the customer provided no usable information.\n\n- Be concise and professional.\n\nAPPROVED QUESTIONS --- refund disputes:\n\n1. Have you received any part of your order?\n\n2. Which items from your order were missing, damaged, wrong, or otherwise affected?\n\n3. What payment method did you use for this order?\n\n4. When was the order placed?\n\nAPPROVED QUESTIONS --- delivery disputes:\n\n1. What is the current tracking status shown to you?\n\n2. Which items from your order were missing or otherwise affected?\n\n3. Has the estimated delivery date passed?\n\n4. Have you contacted the carrier about this issue?\n\nITEM-LEVEL QUESTION GUIDANCE:\n\n- For partial receipt / missing items, ask which items were missing or which items were received.\n\n- For damaged goods, ask which items were damaged.\n\n- For wrong item / wrong variant, ask which items were wrong or affected.\n\n- For other subset-of-order problems, ask what items were affected.\n\nRESPONSE FORMAT --- valid JSON only, no prose, no markdown:\n\n{ \"action\": \"ask_question\" | \"classify_intent\",\n\n\"question\": \"string (only if action=ask_question)\",\n\n\"intent\": \"valid_dispute\" | \"insufficient_context\" (only if classifying),\n\n\"intent_summary\": \"one sentence summary (only if classifying)\" }"
            }
          ]
        }
      },
      "id": "463ac4b5-cd12-4763-8e13-7ea1dd56e7c1",
      "name": "Basic LLM Chain — Intake",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1,
